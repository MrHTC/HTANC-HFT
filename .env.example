# Trading engine defaults to paper mode.
TRADE_MODE=paper

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://trader:trader_pass@localhost:5432/algotrade

# Redis
REDIS_URL=redis://localhost:6379/0

# Telegram approval bot (optional — leave blank for no approval flow)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Angel One credentials (required only for live trading)
ANGELONE_CLIENT_ID=
ANGELONE_API_KEY=
ANGELONE_PASSWORD=
ANGELONE_TOTP_KEY=

# Groww credentials (required only for live trading)
GROWW_CLIENT_ID=
GROWW_API_KEY=

# API key for MCP endpoints
API_KEY=

# Logging
LOG_LEVEL=INFO
